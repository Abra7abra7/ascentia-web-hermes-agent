---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import AIOnboarding from '../components/AIOnboarding.svelte';
import LegalWaiver from '../components/LegalWaiver.astro';
---
<Layout>
  <Header />
  <main class="max-w-4xl mx-auto px-4 py-12">
    <section class="text-center mb-12">
      <h1 class="text-5xl md:text-6xl font-black tracking-tighter text-zinc-50">
        Ascentia: AI-First Learning Platform
      </h1>
      <p class="mt-6 text-xl md:text-2xl font-bold tracking-tight text-zinc-100">
        Prémiové vzdelávanie pre budúcnosť
      </p>
    </section>

    <section class="bg-zinc-900 rounded-2xl p-8">
      <AIOnboarding />
    </section>

    <section class="mt-12">
      <LegalWaiver />
    </section>
  </main>
</Layout>