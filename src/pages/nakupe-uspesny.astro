---
// src/pages/nakupe-uspesny.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---
<Layout>
  <Header />
  <main class="max-w-4xl mx-auto px-4 py-12">
    <section class="text-center">
      <h1 class="text-4xl font-bold text-zinc-50 mb-6">Gratulujeme k nákupu!</h1>
      <p class="text-zinc-400 mb-8">
        Vaša platba bola úspešne spracovaná. Prístup ku kurzom bol odomknutý.
      </p>
      <div class="bg-zinc-950 rounded-xl p-6">
        <h2 class="text-zinc-100 font-semibold mb-4">Ďakujeme, že ste súčasťou komunity Ascentia.</h2>
        <p class="text-zinc-400">
          Začnite svojím vzdelávacím vzostupom hneď. Sledujte svoj e-mail pre ďalšie pokyny a prístup k WhatsApp podpore.
        </p>
        <a href="/" class="inline-block mt-6 bg-violet-600 hover:bg-violet-700 text-zinc-50 font-bold py-3 px-8 rounded-xl transition-all">
          Prejsť na domovskú stránku
        </a>
      </div>
    </section>
  </main>
</Layout>