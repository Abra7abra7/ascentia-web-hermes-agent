---
// src/components/Header.astro
---
<header class="bg-zinc-950 border-b border-zinc-900">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <div class="flex">
        <a href="/" class="flex-shrink-0">
          <img src="/logo.svg" alt="Ascentia Logo" class="h-10 w-auto" />
        </a>
      </div>
      <div class="hidden md:flex md:items-center md:space-x-6">
        <a href="#" class="text-zinc-400 hover:text-zinc-300 transition-colors font-medium">Domov</a>
        <a href="#" class="text-zinc-400 hover:text-zinc-300 transition-colors font-medium">Kurzy</a>
        <a href="#" class="text-zinc-400 hover:text-zinc-300 transition-colors font-medium">O nás</a>
        <a href="#" class="text-zinc-400 hover:text-zinc-300 transition-colors font-medium">Kontakt</a>
      </div>
      <div class="md:hidden">
        <button class="p-2 rounded-md text-zinc-400 hover:text-zinc-300">
          <!-- Hamburger icon placeholder -->
          ☰
        </button>
      </div>
    </div>
  </div>
</header>