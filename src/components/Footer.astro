---
// src/components/Footer.astro
---
<footer class="bg-zinc-900 border-t border-zinc-800">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <h3 class="text-zinc-100 font-semibold mb-4">Ascentia</h3>
        <p class="text-zinc-400">AI-First Learning Platform</p>
      </div>
      <div>
        <h3 class="text-zinc-100 font-semibold mb-4">Navigácia</h3>
        <ul class="space-y-2 text-zinc-400">
          <li><a href="#" class="hover:text-zinc-300 transition-colors">Domov</a></li>
          <li><a href="#" class="hover:text-zinc-300 transition-colors">Kurzy</a></li>
          <li><a href="#" class="hover:text-zinc-300 transition-colors">O nás</a></li>
          <li><a href="#" class="hover:text-zinc-300 transition-colors">Kontakt</a></li>
        </ul>
      </div>
      <div>
        <h3 class="text-zinc-100 font-semibold mb-4">Právne</h3>
        <ul class="space-y-2 text-zinc-400">
          <li><a href="/vop" class="hover:text-zinc-300 transition-colors">VOP</a></li>
          <li><a href="/gdpr" class="hover:text-zinc-300 transition-colors">GDPR</a></li>
        </ul>
        <button id="withdrawal-open" class="mt-4 inline-flex items-center px-3 py-2 border border-zinc-800 text-sm font-medium rounded-md text-zinc-400 hover:text-zinc-300 hover:border-zinc-300">
          Odstúpiť od zmluvy online
        </button>
      </div>
      <div>
        <h3 class="text-zinc-100 font-semibold mb-4">Sledujte nás</h3>
        <div class="flex space-x-4">
          <a href="#" class="text-zinc-400 hover:text-zinc-300 transition-colors">LinkedIn</a>
          <a href="#" class="text-zinc-400 hover:text-zinc-300 transition-colors">Twitter</a>
          <a href="#" class="text-zinc-400 hover:text-zinc-300 transition-colors">Facebook</a>
        </div>
      </div>
    </div>
    <div class="mt-10 pt-8 border-t border-zinc-800 text-center text-xs text-zinc-500">
      © 2026 Ascentia s.r.o. Všetky práva vyhradené.
    </div>
  </div>
</footer>

<!-- Withdrawal Modal (simple) -->
<div id="withdrawal-modal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black bg-opacity-50">
  <div class="bg-zinc-950 rounded-xl p-6 w-full max-w-md">
    <h3 class="text-zinc-100 font-semibold mb-4">Odstúpenie od zmluvy</h3>
    <p class="text-zinc-400 mb-6">
      Prajete si naozaj odstúpiť od zmluvy? Tento krok je nevratný a strácate prístup ku zakúpenému obsahu.
    </p>
    <div class="flex justify-end space-x-3">
      <button id="withdrawal-cancel" class="px-4 py-2 border border-zinc-800 rounded-md text-zinc-400 hover:text-zinc-300">
        Zrušiť
      </button>
      <button id="withdrawal-confirm" class="px-4 py-2 bg-red-600 text-zinc-50 rounded-md hover:bg-red-700 transition-colors">
        Potvrdiť odstúpenie od zmluvy
      </button>
    </div>
  </div>
</div>

<script>
  const openBtn = document.getElementById('withdrawal-open');
  const modal = document.getElementById('withdrawal-modal');
  const cancelBtn = document.getElementById('withdrawal-cancel');
  const confirmBtn = document.getElementById('withdrawal-confirm');

  openBtn.addEventListener('click', () => {
    modal.classList.remove('hidden');
  });

  cancelBtn.addEventListener('click', () => {
    modal.classList.add('hidden');
  });

  confirmBtn.addEventListener('click', () => {
    // In a real app, you would send a request to your backend to process withdrawal.
    alert('Požiadavka na odstúpenie od zmluvy bola odoslaná. Naša podpora vás bude kontaktovať.');
    modal.classList.add('hidden');
  });
</script>